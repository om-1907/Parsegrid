# ═══════════════════════════════════════════════════════════════════════════
# Parsegrid — Environment Variables
# ═══════════════════════════════════════════════════════════════════════════
# Copy this file to `.env` and fill in real values. NEVER commit `.env`.

# ─────────────────────────────────────────────────────────────────────────
# Supabase Configuration
# ─────────────────────────────────────────────────────────────────────────

# Your Supabase project URL (used by the frontend JS client).
# Example: https://xyzcompany.supabase.co
SUPABASE_URL="https://your-project-ref.supabase.co"

# Supabase anon (public) key — SAFE to expose in frontend code.
# Used by the Next.js client for unauthenticated/public API calls.
SUPABASE_ANON_KEY="your-supabase-anon-key"

# Supabase service_role key — NEVER expose in frontend code.
# Used by the FastAPI backend for admin operations that bypass RLS.
SUPABASE_SERVICE_ROLE_KEY="your-supabase-service-role-key"

# ─────────────────────────────────────────────────────────────────────────
# Backend Database Connection (FastAPI + SQLAlchemy)
# ─────────────────────────────────────────────────────────────────────────

# Async PostgreSQL connection string (SQLAlchemy + asyncpg driver).
# Use the Supavisor transaction pooler (port 6543) for production,
# NOT the direct Postgres connection (port 5432) — to prevent connection exhaustion.
#
# Transaction pooler (recommended for FastAPI):
#   postgresql+asyncpg://postgres.ref:password@aws-0-region.pooler.supabase.com:6543/postgres
#
# Direct connection (for migrations only):
#   postgresql+asyncpg://postgres:password@db.ref.supabase.co:5432/postgres
DATABASE_URL="postgresql+asyncpg://postgres.ref:password@aws-0-region.pooler.supabase.com:6543/postgres"

# ─────────────────────────────────────────────────────────────────────────
# AI / LLM Configuration
# ─────────────────────────────────────────────────────────────────────────

# Google Gemini API keys (https://aistudio.google.com/apikey)
# You can provide multiple keys separated by commas to handle rate limits (fallback).
GEMINI_API_KEYS="your-gemini-api-key-1,your-gemini-api-key-2"
# GEMINI_API_KEY="your-gemini-api-key" # Legacy single key support

# Chat + embedding models (LiteLLM identifiers). Defaults shown.
# LLM_MODEL="gemini/gemini-2.5-flash"
# EMBEDDING_MODEL="gemini/gemini-embedding-001"
# Embedding vector size. MUST match the vector() size of the document_chunks.embedding
# column in the DB (and stay <= 2000 so the pgvector HNSW index is valid).
# gemini-embedding-001 defaults to 3072; we request 768 to fit the column + index.
# EMBEDDING_DIMENSIONS=768

# ─────────────────────────────────────────────────────────────────────────
# Security
# ─────────────────────────────────────────────────────────────────────────

# Secret used to sign JWT access tokens. MUST be at least 32 characters.
# Generate a strong random value:
#   python -c "import secrets; print(secrets.token_urlsafe(48))"
JWT_SECRET_KEY="change-me-generate-a-long-random-string-at-least-32-chars"

# ─────────────────────────────────────────────────────────────────────────
# Application Settings
# ─────────────────────────────────────────────────────────────────────────

# Environment: "development" or "production".
# In production, cookies are set with Secure=True (HTTPS only).
ENVIRONMENT="development"

# Set to true to enable SQL echo / verbose logging.
DEBUG="false"

# When true, the DB TLS connection skips CA/hostname verification.
# Required for local dev against the Supabase pooler's private CA.
# MUST be false in production.
DB_SSL_INSECURE="false"
