# Copy this file to `.env` and fill in real values. NEVER commit `.env`.

# Google Gemini API key (https://aistudio.google.com/apikey)
GEMINI_API_KEY="your-gemini-api-key"

# Async PostgreSQL connection string (SQLAlchemy + asyncpg driver).
# Example (Supabase pooler): postgresql+asyncpg://user:password@host:5432/postgres
DATABASE_URL="postgresql+asyncpg://user:password@host:5432/postgres"

# Secret used to sign JWT access tokens. Generate a strong random value, e.g.:
#   python -c "import secrets; print(secrets.token_urlsafe(48))"
JWT_SECRET_KEY="change-me-generate-a-long-random-string"

# Environment: "development" or "production".
# In production, cookies are set with Secure=True (HTTPS only).
ENVIRONMENT="development"

# Set to true to enable SQL echo / verbose logging.
DEBUG="false"
